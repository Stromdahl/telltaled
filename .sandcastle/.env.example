# Copy to .sandcastle/.env and fill in. Sandcastle resolves agent auth from this
# file or from process.env. .env is gitignored — never commit real tokens.

# Preferred: a Claude Code OAuth token (generate with `claude setup-token`).
CLAUDE_CODE_OAUTH_TOKEN=

# Alternative: an Anthropic API key (used if no OAuth token is set).
# ANTHROPIC_API_KEY=sk-ant-...
